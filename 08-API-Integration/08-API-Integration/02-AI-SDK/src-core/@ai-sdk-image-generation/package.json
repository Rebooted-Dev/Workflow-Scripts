{
  "name": "@ai-sdk/image-generation",
  "version": "1.0.0-beta.1",
  "description": "A comprehensive, multi-provider image generation library built on the AI SDK",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "ai",
    "sdk",
    "image-generation",
    "openai",
    "google",
    "xai",
    "fal",
    "dall-e",
    "imagen",
    "flux",
    "stable-diffusion"
  ],
  "author": "Jesse Ng",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-repo/ai-sdk-image-generation"
  },
  "bugs": {
    "url": "https://github.com/your-repo/ai-sdk-image-generation/issues"
  },
  "homepage": "https://github.com/your-repo/ai-sdk-image-generation#readme",
  "peerDependencies": {
    "@ai-sdk/fal": "^1.0.18",
    "@ai-sdk/google": "^2.0.17",
    "@ai-sdk/openai": "^2.0.42",
    "@ai-sdk/xai": "^2.0.23",
    "@fal-ai/client": "^1.7.0",
    "ai": "^5.0.60",
    "zod": "^4.1.11"
  },
  "peerDependenciesMeta": {
    "@ai-sdk/openai": {
      "optional": true
    },
    "@ai-sdk/google": {
      "optional": true
    },
    "@ai-sdk/xai": {
      "optional": true
    },
    "@ai-sdk/fal": {
      "optional": true
    },
    "@fal-ai/client": {
      "optional": true
    }
  },
  "devDependencies": {
    "@ai-sdk/google": "2.0.74",
    "@ai-sdk/openai": "2.0.106",
    "@ai-sdk/xai": "2.0.73",
    "@fal-ai/client": "1.10.1",
    "@types/node": "^22.14.0",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "typescript": "~5.7.2",
    "vite": "^6.2.0",
    "vitest": "^3.2.4"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write src/**/*.{ts,js}",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run test:run"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "dotenv": "^17.2.3"
  }
}
