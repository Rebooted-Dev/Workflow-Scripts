#!/usr/bin/env python3
import argparse
import datetime as dt
import json
import os
import re
import shutil
import subprocess
import sys
from pathlib import Path

VALID_KINDS = {"workflow", "reference", "template", "policy", "role", "skill", "standard"}
GENERATED = "<!-- Generated by tools/wf build. Do not edit by hand. -->"
ROUTE_STOP_WORDS = {"a", "an", "and", "for", "of", "please", "the", "this", "to", "workflow"}


def root() -> Path:
    if os.environ.get("WF_ROOT"):
        return Path(os.environ["WF_ROOT"]).resolve()
    cwd = Path.cwd().resolve()
    if cwd.name == "workflows-drag-free":
        return cwd
    active = cwd / "workflows-drag-free"
    if active.exists():
        return active.resolve()
    return cwd


def metadata_root(base: Path) -> Path:
    if os.environ.get("WF_ROOT"):
        return base
    if base.name == "workflows-drag-free" and (base.parent / "00-project").exists():
        return base.parent
    return base


def rel(path: Path, base: Path) -> str:
    return path.relative_to(base).as_posix()


def slugify(text: str) -> str:
    text = re.sub(r"[^a-z0-9]+", "-", text.lower()).strip("-")
    return text or "item"


def today() -> str:
    return dt.date.today().isoformat()


def read_text(path: Path) -> str:
    return path.read_text(encoding="utf-8")


def write_text(path: Path, text: str) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(text, encoding="utf-8")


def split_frontmatter(text: str):
    if not text.startswith("---\n"):
        return {}, text
    end = text.find("\n---\n", 4)
    if end == -1:
        return {"__error__": "unterminated frontmatter"}, text
    return parse_yamlish(text[4:end]), text[end + 5 :]


def parse_scalar(value: str):
    value = value.strip()
    if value.startswith("[") and value.endswith("]"):
        inner = value[1:-1].strip()
        if not inner:
            return []
        return [parse_scalar(part) for part in inner.split(",")]
    return value.strip("\"'")


def parse_yamlish(src: str) -> dict:
    data = {}
    lines = src.splitlines()
    i = 0
    while i < len(lines):
        line = lines[i]
        if not line.strip() or line.lstrip().startswith("#"):
            i += 1
            continue
        if not line.startswith(" ") and ":" in line:
            key, value = line.split(":", 1)
            key = key.strip()
            value = value.strip()
            if value:
                data[key] = parse_scalar(value)
                i += 1
                continue
            block = []
            nested = {}
            i += 1
            while i < len(lines) and (lines[i].startswith(" ") or not lines[i].strip()):
                item = lines[i].strip()
                if item.startswith("- "):
                    block.append(parse_scalar(item[2:]))
                elif ":" in item:
                    nkey, nvalue = item.split(":", 1)
                    nested[nkey.strip()] = parse_scalar(nvalue.strip())
                i += 1
            data[key] = block if block else nested
            continue
        i += 1
    return data


def markdown_files(base: Path):
    skip_parts = {".git", "node_modules", ".venv", "Workflow-Scripts-consolidated", "dist"}
    for path in sorted(base.rglob("*.md")):
        if any(part in skip_parts for part in path.parts):
            continue
        path_rel = rel(path, base)
        if path_rel.startswith("00-project/Drag-Free-v2/"):
            continue
        if path_rel.startswith("00-Drag-Free-v2/"):
            continue
        yield path


def records(base: Path):
    found = []
    for path in markdown_files(base):
        fm, body = split_frontmatter(read_text(path))
        if "__error__" in fm:
            found.append({"path": rel(path, base), "body": body, "frontmatter_error": fm["__error__"]})
            continue
        if not fm:
            continue
        rec = dict(fm)
        rec["path"] = rel(path, base)
        rec["body"] = body
        if "title" not in rec:
            title = first_heading(body) or Path(path).stem.replace("-", " ").title()
            rec["title"] = title
        found.append(rec)
    return found


def first_heading(body: str) -> str:
    for line in body.splitlines():
        if line.startswith("# "):
            return line[2:].strip()
    return ""


def visible_record(rec: dict) -> dict:
    out = {}
    for key in sorted(k for k in rec if k != "body"):
        out[key] = rec[key]
    return out


def build_outputs(base: Path):
    recs = sorted(records(base), key=lambda r: (str(r.get("category", "")), str(r.get("id", "")), r["path"]))
    catalog = {
        "generated_by": "tools/wf build",
        "records": [visible_record(r) for r in recs],
        "redirects": load_redirects(base),
    }
    router_rows = []
    for rec in recs:
        if rec.get("kind") != "workflow":
            continue
        triggers = rec.get("triggers", [])
        if isinstance(triggers, str):
            triggers = [triggers]
        router_rows.append(
            "| `{}` | {} | `{}` | {} | {} |".format(
                rec.get("id", ""),
                rec.get("category", ""),
                rec.get("path", ""),
                "; ".join(map(str, triggers)),
                rec.get("next", ""),
            )
        )
    router = "\n".join(
        [
            GENERATED,
            "",
            "# Workflow Router",
            "",
            "Use this compact index before reading the full workflow library.",
            "",
            "| Workflow | Category | Path | Triggers | Next |",
            "|---|---|---|---|---|",
            *router_rows,
            "",
        ]
    )
    return {
        "catalog.json": json.dumps(catalog, indent=2, sort_keys=True) + "\n",
        "ROUTER.md": router,
    }


def load_redirects(base: Path) -> dict:
    moved = base / "MOVED.json"
    if not moved.exists():
        return {}
    try:
        data = json.loads(read_text(moved))
        if isinstance(data, dict):
            return data
    except Exception:
        return {}
    return {}


def cmd_validate(args) -> int:
    base = root()
    recs = records(base)
    errors = []
    warnings = []
    ids = {}
    role_ids = {r.get("id") for r in recs if r.get("kind") == "role" and r.get("id")}
    for rec in recs:
        path = rec["path"]
        if rec.get("frontmatter_error"):
            errors.append(f"{path}: {rec['frontmatter_error']}")
        rid = rec.get("id")
        if rid:
            if rid in ids:
                errors.append(f"{path}: duplicate id {rid!r} also used by {ids[rid]}")
            ids[rid] = path
        kind = rec.get("kind")
        if kind and kind not in VALID_KINDS:
            errors.append(f"{path}: invalid kind {kind!r}")
        if kind == "workflow":
            for field in ("id", "version", "category"):
                if not rec.get(field):
                    errors.append(f"{path}: workflow missing required field {field!r}")
            triggers = rec.get("triggers", rec.get("trigger", []))
            if isinstance(triggers, str):
                triggers = [triggers]
            if not triggers or not any(str(trigger).strip() for trigger in triggers):
                errors.append(f"{path}: workflow requires at least one trigger")
        agents = rec.get("agents", [])
        if isinstance(agents, str):
            agents = [agents]
        for agent in agents:
            if not agent or agent in role_ids:
                continue
            errors.append(f"{path}: unresolved role reference {agent!r}")
        body = rec.get("body", "")
        for bad in ("02-build-code", "03-debug/", "05-review-audit", "../02-build-code", "../../02-build-code"):
            if bad in body:
                warnings.append(f"{path}: stale path reference {bad}")
        for target in markdown_links(strip_fenced_code(body)):
            if is_external(target) or target.startswith("#") or target.startswith("mailto:"):
                continue
            clean = target.split("#", 1)[0]
            if not clean:
                continue
            resolved = (base / path).parent / clean
            if not resolved.exists():
                warnings.append(f"{path}: broken markdown link {target}")
    for path in markdown_files(base):
        fm, body = split_frontmatter(read_text(path))
        path_rel = rel(path, base)
        top_level = Path(path_rel).parts[0]
        if top_level in {"00-core", "00-project", "reference", "templates", "tools"}:
            continue
        if not first_heading(body).lower().startswith("workflow:"):
            continue
        if not fm:
            errors.append(f"{path_rel}: executable workflow missing frontmatter")
        elif fm.get("kind") != "workflow":
            errors.append(f"{path_rel}: executable workflow requires kind 'workflow'")

    # References are resolved only after all IDs have been collected, so forward
    # edges and dependencies behave the same as backward ones.
    by_id = {}
    for rec in recs:
        rid = rec.get("id")
        if rid:
            by_id.setdefault(rid, []).append(rec)
    for rec in recs:
        path = rec["path"]
        for field in ("requires", "prev", "next"):
            targets = rec.get(field, [])
            if isinstance(targets, str):
                targets = [targets]
            if not isinstance(targets, list):
                errors.append(f"{path}: {field} must be a scalar or list of record IDs")
                continue
            for target in targets:
                matches = by_id.get(target, [])
                if len(matches) != 1:
                    errors.append(f"{path}: unresolved {field} reference {target!r}")
                    continue
                if field in ("prev", "next") and matches[0].get("kind") != "workflow":
                    errors.append(f"{path}: {field} reference {target!r} targets non-workflow record")
    phrase = "Completion requires evidence, not intent."
    core_has_phrase = any(phrase in read_text(base / r["path"]) for r in recs if r["path"].startswith("00-core/"))
    if core_has_phrase:
        for rec in recs:
            if rec["path"].startswith("00-core/"):
                continue
            if phrase in rec.get("body", ""):
                errors.append(f"{rec['path']}: duplicates core phrase {phrase!r}")
    for warning in warnings:
        print(f"warning: {warning}")
    if errors:
        for error in errors:
            print(f"error: {error}", file=sys.stderr)
        return 1
    print(f"Validated {len(recs)} frontmatter records with {len(warnings)} warnings")
    return 0


def markdown_links(text: str):
    return re.findall(r"(?<!!)\[[^\]]+\]\(([^)]+)\)", text)


def strip_fenced_code(text: str) -> str:
    """Blank well-formed fenced blocks while preserving line numbers.

    Malformed Markdown is intentionally returned unchanged so an unterminated
    fence cannot hide links from validation.
    """
    lines = text.splitlines(keepends=True)
    stripped = list(lines)
    opener = None
    start = 0
    for index, line in enumerate(lines):
        content = line.rstrip("\r\n")
        if opener is None:
            match = re.match(r"^( {0,3})(`{3,}|~{3,})(.*)$", content)
            if not match:
                continue
            fence = match.group(2)
            opener = (fence[0], len(fence))
            start = index
            continue
        char, minimum = opener
        if re.match(rf"^ {{0,3}}{re.escape(char)}{{{minimum},}}[ \t]*$", content):
            for fenced_index in range(start, index + 1):
                ending = "\n" if lines[fenced_index].endswith("\n") else ""
                stripped[fenced_index] = ending
            opener = None
    return text if opener is not None else "".join(stripped)


def is_external(target: str) -> bool:
    return bool(re.match(r"^[a-zA-Z][a-zA-Z0-9+.-]*:", target))


def cmd_build(args) -> int:
    base = root()
    if getattr(args, "skills", False):
        return build_skills(base, check=args.check)
    outputs = build_outputs(base)
    stale = []
    for name, content in outputs.items():
        path = base / name
        if args.check:
            if not path.exists() or read_text(path) != content:
                stale.append(name)
        else:
            write_text(path, content)
    if args.check:
        if stale:
            for name in stale:
                print(f"{name} is stale", file=sys.stderr)
            return 1
        print("generated files are fresh")
    else:
        print("generated files updated")
    return 0


def build_skills(base: Path, check: bool = False) -> int:
    skill_base = base if (base / "11-Skills").exists() else metadata_root(base)
    skill_root = skill_base / "11-Skills"
    outputs = {}
    if skill_root.exists():
        for skill_md in sorted(skill_root.glob("*/SKILL.md")):
            skill = skill_md.parent.name
            content = read_text(skill_md)
            for target in ("codex", "claude", "opencode", "droid"):
                outputs[f"dist/skills/{target}/{skill}/SKILL.md"] = content
    stale = []
    for name, content in outputs.items():
        path = skill_base / name
        if check:
            if not path.exists() or read_text(path) != content:
                stale.append(name)
        else:
            write_text(path, content)
    manifest = {"generated_by": "tools/wf build skills", "skills": sorted({Path(k).parts[3] for k in outputs})}
    manifest_path = skill_base / "dist/skills/manifest.json"
    manifest_content = json.dumps(manifest, indent=2, sort_keys=True) + "\n"
    if check:
        if not manifest_path.exists() or read_text(manifest_path) != manifest_content:
            stale.append("dist/skills/manifest.json")
        if stale:
            for name in stale:
                print(f"{name} is stale", file=sys.stderr)
            return 1
        print("skill bundles are fresh")
    else:
        write_text(manifest_path, manifest_content)
        print("skill bundles updated")
    return 0


def cmd_route(args) -> int:
    base = root()
    query = " ".join(args.query)
    normalized_query = normalize_phrase(query)
    workflows = [rec for rec in records(base) if rec.get("kind") == "workflow"]

    exact_ids = [rec for rec in workflows if str(rec.get("id", "")).lower() == query.strip().lower()]
    if len(exact_ids) == 1:
        print(json.dumps(visible_record(exact_ids[0]), indent=2, sort_keys=True))
        return 0

    exact_triggers = []
    for rec in workflows:
        triggers = rec.get("triggers", rec.get("trigger", []))
        if isinstance(triggers, str):
            triggers = [triggers]
        if any(normalize_phrase(str(trigger)) == normalized_query for trigger in triggers):
            exact_triggers.append(rec)
    if len(exact_triggers) == 1:
        print(json.dumps(visible_record(exact_triggers[0]), indent=2, sort_keys=True))
        return 0
    if len(exact_triggers) > 1:
        return route_error(query, exact_triggers)

    query_tokens = set(normalized_query.split()) - ROUTE_STOP_WORDS
    scored = []
    for rec in workflows:
        triggers = rec.get("triggers", rec.get("trigger", []))
        if isinstance(triggers, str):
            triggers = [triggers]
        searchable = [rec.get("id", ""), *triggers]
        tokens = set(normalize_phrase(" ".join(map(str, searchable))).split())
        score = len(query_tokens & tokens)
        if score:
            scored.append((score, rec))
    if not scored:
        return route_error(query, [])
    top_score = max(score for score, _ in scored)
    winners = [rec for score, rec in scored if score == top_score]
    if len(winners) != 1:
        return route_error(query, winners)
    print(json.dumps(visible_record(winners[0]), indent=2, sort_keys=True))
    return 0


def normalize_phrase(text: str) -> str:
    return " ".join(re.findall(r"[a-z0-9]+", text.lower()))


def route_error(query: str, matches: list) -> int:
    if matches:
        ids = ", ".join(sorted(str(rec.get("id", "")) for rec in matches))
        print(f"ambiguous workflow route for {query!r}: {ids}", file=sys.stderr)
    else:
        print(f"unknown workflow route for {query!r}", file=sys.stderr)
    return 2


def ensure_index(path: Path, title: str, columns: str, separator: str) -> None:
    if not path.exists():
        write_text(path, f"# {title}\n\n{columns}\n{separator}\n")


def insert_row(index: Path, row: str) -> None:
    ensure_index(index, index.stem.title(), "| Date | Type | Title | File | Notes |", "|------|------|-------|------|-------|")
    lines = read_text(index).splitlines()
    sep = next((i for i, line in enumerate(lines) if re.match(r"^\|[- |]+\|$", line)), None)
    if sep is None:
        lines.extend(["| Date | Type | Title | File | Notes |", "|------|------|-------|------|-------|"])
        sep = len(lines) - 1
    lines.insert(sep + 1, row)
    write_text(index, "\n".join(lines) + "\n")


def cmd_log(args) -> int:
    base = root()
    meta = metadata_root(base)
    date = today()
    slug = slugify(args.title)
    out = meta / "00-project" / "changelog" / args.type / f"{date}-{args.type}-{slug}.md"
    content = f"---\ndate: {date}\ntype: {args.type}\ntitle: {args.title}\n---\n\n# {args.title}\n\n{args.notes or ''}\n"
    write_text(out, content)
    row = f"| {date} | {args.type} | {args.title} | {args.type}/{out.name} | {args.notes or ''} |"
    insert_row(meta / "00-project/changelog/index.md", row)
    print(rel(out, meta))
    return 0


def cmd_trouble(args) -> int:
    base = root()
    meta = metadata_root(base)
    date = today()
    title = args.title or args.slug.replace("-", " ").title()
    out = meta / "00-project" / "troubleshooting" / args.category / f"{date}-{args.category}-{slugify(args.slug)}.md"
    content = f"---\ndate: {date}\ncategory: {args.category}\ntitle: {title}\nstatus: {args.status}\n---\n\n# {title}\n"
    write_text(out, content)
    index = meta / "00-project/troubleshooting/index.md"
    ensure_index(index, "Troubleshooting Index", "| Date | Category | Title | File | Status |", "|------|----------|-------|------|--------|")
    insert_row(index, f"| {date} | {args.category} | {title} | {args.category}/{out.name} | {args.status} |")
    print(rel(out, meta))
    return 0


def cmd_new_plan(args) -> int:
    base = root()
    meta = metadata_root(base)
    date = today()
    title = args.title or args.slug.replace("-", " ").title()
    out = meta / "00-project" / "plans" / args.slug / f"{date}-{args.slug}.md"
    write_text(out, f"# {title}\n\n## Tasks\n\n- [ ] Define implementation steps\n")
    print(rel(out, meta))
    return 0


def plan_title(path: Path) -> str:
    for line in read_text(path).splitlines():
        if line.startswith("# "):
            return line[2:].strip()
    return path.stem.replace("-", " ").title()


def cmd_file_completed(args) -> int:
    base = root()
    meta = metadata_root(base)
    src = meta / args.plan
    if not src.exists():
        print("source plan does not exist", file=sys.stderr)
        return 1
    dest = meta / "00-project" / "plans-completed" / args.category / src.name
    dest.parent.mkdir(parents=True, exist_ok=True)
    shutil.move(str(src), str(dest))
    title = plan_title(dest)
    date = today()
    insert_row(meta / "00-project/plans-completed/index.md", f"| {date} | {args.category} | {title} | {args.category}/{dest.name} | completed |")
    insert_row(meta / "00-project/changelog/index.md", f"| {date} | plan | {title} | ../plans-completed/{args.category}/{dest.name} | Completed plan filed. |")
    print(rel(dest, meta))
    return 0


def cmd_debt(args) -> int:
    if args.debt_cmd == "add":
        base = root()
        meta = metadata_root(base)
        date = today()
        out = meta / "00-project" / "debt" / args.category / f"{date}-{args.category}-{slugify(args.title)}.md"
        write_text(out, f"---\ndate: {date}\ncategory: {args.category}\ntitle: {args.title}\nstatus: open\n---\n\n# {args.title}\n\n{args.notes or ''}\n")
        insert_row(meta / "00-project/debt/index.md", f"| {date} | {args.category} | {args.title} | {args.category}/{out.name} | open |")
        print(rel(out, meta))
        return 0
    if args.debt_cmd == "list":
        base = root()
        meta = metadata_root(base)
        rows = []
        for path in sorted((meta / "00-project/debt").glob("*/*.md")):
            fm, body = split_frontmatter(read_text(path))
            if args.status and fm.get("status") != args.status:
                continue
            rows.append({"title": fm.get("title") or first_heading(body), "status": fm.get("status"), "path": rel(path, meta)})
        print(json.dumps(rows, indent=2, sort_keys=True))
        return 0
    return 1


def cmd_run(args) -> int:
    base = root()
    workflows = {rec.get("id") for rec in records(base) if rec.get("kind") == "workflow"}
    if args.workflow_id not in workflows:
        print(f"unknown workflow id {args.workflow_id!r}", file=sys.stderr)
        return 2
    if args.workflow_id != "plan-review":
        print(f"workflow {args.workflow_id!r} is not supported by wf run", file=sys.stderr)
        return 2
    output = base / args.output
    orch = base / "tools/orchestrator/orchestrator-review.sh"
    if not orch.exists():
        print("orchestrator-review.sh not found", file=sys.stderr)
        return 1
    cmd = [str(orch), args.plan, "--output", str(output)]
    if args.timeout:
        cmd.extend(["--timeout", args.timeout])
    proc = subprocess.run(cmd, cwd=base)
    manifest = {
        "workflow_id": args.workflow_id,
        "plan": args.plan,
        "output": rel(output, base),
        "status": "completed" if proc.returncode == 0 else "failed",
        "exit_code": proc.returncode,
    }
    write_text(output.parent / "_manifest.json", json.dumps(manifest, indent=2, sort_keys=True) + "\n")
    return proc.returncode


def cmd_stats(args) -> int:
    if args.stats_cmd == "runs":
        base = root()
        target = base / args.path
        manifests = list(target.rglob("_manifest.json")) if target.exists() else []
        statuses = {}
        workflows = {}
        for manifest in manifests:
            data = json.loads(read_text(manifest))
            statuses[data.get("status", "unknown")] = statuses.get(data.get("status", "unknown"), 0) + 1
            workflows[data.get("workflow_id", "unknown")] = workflows.get(data.get("workflow_id", "unknown"), 0) + 1
        print(json.dumps({"runs": len(manifests), "statuses": statuses, "workflows": workflows}, indent=2, sort_keys=True))
        return 0
    if args.stats_cmd == "tokens":
        base = root()
        counts = [{"path": rel(p, base), "tokens": len(read_text(p).split())} for p in markdown_files(base)]
        print(json.dumps({"files": counts}, indent=2, sort_keys=True))
        return 0
    return 1


def main(argv=None) -> int:
    parser = argparse.ArgumentParser(prog="wf")
    sub = parser.add_subparsers(dest="cmd", required=True)
    sub.add_parser("validate")
    build = sub.add_parser("build")
    build.add_argument("build_target", nargs="?")
    build.add_argument("--check", action="store_true")
    route = sub.add_parser("route")
    route.add_argument("query", nargs="+")
    log = sub.add_parser("log")
    log.add_argument("type")
    log.add_argument("title")
    log.add_argument("--notes", default="")
    trouble = sub.add_parser("trouble")
    trouble.add_argument("category")
    trouble.add_argument("slug")
    trouble.add_argument("--title")
    trouble.add_argument("--status", default="open")
    new = sub.add_parser("new")
    new_sub = new.add_subparsers(dest="new_cmd", required=True)
    plan = new_sub.add_parser("plan")
    plan.add_argument("slug")
    plan.add_argument("--title")
    file_completed = sub.add_parser("file-completed")
    file_completed.add_argument("plan")
    file_completed.add_argument("category")
    debt = sub.add_parser("debt")
    debt_sub = debt.add_subparsers(dest="debt_cmd", required=True)
    debt_add = debt_sub.add_parser("add")
    debt_add.add_argument("category")
    debt_add.add_argument("title")
    debt_add.add_argument("--notes", default="")
    debt_list = debt_sub.add_parser("list")
    debt_list.add_argument("--status")
    run = sub.add_parser("run")
    run.add_argument("workflow_id")
    run.add_argument("plan")
    run.add_argument("--output", required=True)
    run.add_argument("--timeout")
    stats = sub.add_parser("stats")
    stats_sub = stats.add_subparsers(dest="stats_cmd", required=True)
    stats_runs = stats_sub.add_parser("runs")
    stats_runs.add_argument("path")
    stats_sub.add_parser("tokens")

    args = parser.parse_args(argv)
    if args.cmd == "validate":
        return cmd_validate(args)
    if args.cmd == "build":
        args.skills = args.build_target == "skills"
        return cmd_build(args)
    if args.cmd == "route":
        return cmd_route(args)
    if args.cmd == "log":
        return cmd_log(args)
    if args.cmd == "trouble":
        return cmd_trouble(args)
    if args.cmd == "new":
        return cmd_new_plan(args)
    if args.cmd == "file-completed":
        return cmd_file_completed(args)
    if args.cmd == "debt":
        return cmd_debt(args)
    if args.cmd == "run":
        return cmd_run(args)
    if args.cmd == "stats":
        return cmd_stats(args)
    return 1


