-    });
-
-    async function encodeImage(imagePath) {
-      try {
-        const imageBuffer = await fs.readFile(imagePath);
-        return imageBuffer.toString('base64');
-      } catch (error) {
-        console.error("Error encoding image:", error);
-        return null;
-      }
-    }
-
