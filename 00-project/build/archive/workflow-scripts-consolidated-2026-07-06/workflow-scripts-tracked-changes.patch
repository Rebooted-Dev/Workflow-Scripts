-    port: 5173,
-    strictPort: false,
-    open: true,  // ✅ Auto-open browser
-  },
-})
-```
-
-### Custom Browser
-
-```typescript
-export default defineConfig({
-  server: {
-    open: {
-      browser: 'chrome',  // 'firefox', 'safari', etc.
-      url: 'http://localhost:5173/custom-path'
-    },
-  },
-})
-```
-
-### Alternative: Using npm Scripts
-
-**macOS/Linux:**
-```json
-{
-  "scripts": {
-    "dev": "vite & sleep 2 && open http://localhost:5173"
-  }
-}
-```
-
-**Windows:**
