-
-```bash
-#!/bin/bash
-# Run Lighthouse CI (automated)
-npx lighthouse https://{{DOMAIN}} --output=json --output-path=lighthouse-report-$(date +%Y%m%d).json
-
-# Automated: Check thresholds
