-const model = xai('grok-3');
-```
-
-### Example
-
-You can use xAI language models to generate text with the `generateText` function:
-
-```ts
-import { xai } from '@ai-sdk/xai';
-import { generateText } from 'ai';
-
-const { text } = await generateText({
-  model: xai('grok-3'),
